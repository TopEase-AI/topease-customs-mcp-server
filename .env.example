# MCP 配置示例
# 将此文件复制为 .env 并填入你的配置

# API密钥列表，用逗号分隔（至少设置一个）
# 第三方大模型调用MCP时必须提供此密钥
API_KEYS=topease-customs-key-001,topease-customs-key-002

# 海关数据API地址
CUSTOMS_API_BASE_URL=https://api.topease.net

# PostgreSQL数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/topease
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/topease
